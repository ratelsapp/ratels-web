{
  "canisters": {
    "ratel_new_backend": {
      "main": "src/ratel_new_backend/main.mo",
      "type": "motoko"
    },
    "ratel_new_frontend": {
      "dependencies": [
        "ratel_new_backend"
      ],
      "frontend": {
        "entrypoint": "src/ratel_new_frontend/src/index.html"
      },
      "source": [
        "dist/ratel_new_frontend/"
      ],
      "type": "assets"
    }
  },
  "defaults": {
    "build": {
      "packtool": ""
    }
  },
  "dfx": "0.11.1",
  "networks": {
    "local": {
      "bind": "127.0.0.1:8000",
      "type": "ephemeral"
    },
    "test": {
      "providers": ["https://ic0.app"],
      "type": "persistent"
    },
    "ic": {
      "providers": ["https://ic0.app"],
      "type": "persistent"
    }
  },
  "version": 1
}